# API Server - copy to .env and fill in values
PORT=5000
NODE_ENV=production

# Supabase PostgreSQL (Render'da ilan kaydı için — Supabase Dashboard > Settings > Database)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Firebase Auth (API token verification — sadece project ID yeterli)
FIREBASE_PROJECT_ID=pazaryeri0

# Google OAuth (eski mobil sürümler için yönlendirme — secret artık zorunlu değil)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
API_PUBLIC_URL=https://pazaryerim.onrender.com
SITE_PUBLIC_URL=https://pazaryeri0.web.app

CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=pazaryeri-listings
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ImgBB — birincil depolama (api.imgbb.com). Çoklu key: virgülle ayırın
IMGBB_API_KEY=your-imgbb-api-key
IMGBB_API_KEYS=key1,key2

# Backblaze B2 — 10 GB ücretsiz (isteğe bağlı, R2 yedeği)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET_NAME=pazaryeri-listings
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/pazaryeri-listings
B2_REGION=us-west-004
