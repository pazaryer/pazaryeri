{
  "expo": {
    "name": "Pazaryeri",
    "slug": "pazaryeri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pazaryeri",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E31E24"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pazaryerim",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "İlan fotoğrafı çekmek için kamera erişimi gerekli.",
        "NSPhotoLibraryUsageDescription": "İlan fotoğrafı seçmek için galeri erişimi gerekli.",
        "NSLocationWhenInUseUsageDescription": "Konumunuzu ilanınıza eklemek için konum erişimi gerekli."
      }
    },
    "android": {
      "package": "com.pazaryerim",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E31E24"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://pazaryeri0.web.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E31E24"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "İlan fotoğrafı seçmek için galeri erişimi gerekli.",
          "cameraPermission": "İlan fotoğrafı çekmek için kamera erişimi gerekli."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Konumunuzu ilanınıza eklemek için konum erişimi gerekli."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "pazaryeri"
      },
      "siteUrl": "https://pazaryeri0.web.app",
      "apiUrl": "https://pazaryerim.onrender.com",
      "firebase": {
        "apiKey": "AIzaSyB6W3BBz1_SpD-jp8dcpvFTjeBwnZlw4Dg",
        "authDomain": "pazaryeri0.firebaseapp.com",
        "projectId": "pazaryeri0",
        "storageBucket": "pazaryeri0.firebasestorage.app",
        "messagingSenderId": "445495602976",
        "appId": "1:445495602976:web:a9d405b30d0cab7d85f145",
        "measurementId": "G-X4KF641X5R"
      },
      "google": {
        "webClientId": "445495602976-7sqmtkk198ucafhpgsc0girnbvuujh20.apps.googleusercontent.com"
      },
      "router": {
        "origin": "https://pazaryeri0.web.app"
      }
    },
    "owner": "pazaryeri"
  }
